# ── STEP 1: Pick ONE provider and add its key ─────────────────────────────────

# OPTION A (RECOMMENDED) — Groq: free, fast, no credit card, takes 2 min
# console.groq.com → Login with Google → API Keys → Create free key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTION B — Google AI Studio: free but quota can be strict
# aistudio.google.com → "Get API key"
# GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTION C — OpenRouter: free models, rate-limited at peak hours
# openrouter.ai → sign up → Keys → Create key
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── STEP 2 (optional): override the default model ────────────────────────────
# Groq defaults: llama-3.3-70b-versatile
# Gemini defaults: gemini-2.0-flash
# OpenRouter defaults: meta-llama/llama-3.3-70b-instruct:free
# GEN_MODEL=llama-3.3-70b-versatile
